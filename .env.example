# ════════════════════════════════════════════════════════════════════
#  Aura AI Research Platform — Environment Variables
#  Copy this file to .env.local and fill in your values.
#  .env.local is gitignored and safe to store secrets.
# ════════════════════════════════════════════════════════════════════

# ─── Gemini API Keys ─────────────────────────────────────────────────
#
#  Add keys from up to 5 different Google accounts.
#  The app automatically rotates between them when one hits a rate limit.
#  Each key gets its own status tracking (available / cooling / exhausted).
#  A minimum of 1 key is required. 4+ keys recommended for production.
#
#  Get keys at: https://aistudio.google.com/app/apikey
#  (Each Google account = 1 free key with its own quota)
#
GEMINI_API_KEY=          # Primary key (can be the same as KEY_1 or a different account)
GEMINI_API_KEY_1=        # Account 1 key
GEMINI_API_KEY_2=        # Account 2 key
GEMINI_API_KEY_3=        # Account 3 key
GEMINI_API_KEY_4=        # Account 4 key
GEMINI_API_KEY_5=        # Account 5 key (optional bonus)

# ─── Search Provider ─────────────────────────────────────────────────
#
#  Tavily is used for parallel web search (Wikipedia, LinkedIn, etc.)
#  Get a free key at: https://tavily.com
#  Free tier: 1,000 searches/month
#
TAVILY_API_KEY=          # Required

# ─── Cache (Optional) ────────────────────────────────────────────────
#
#  Redis dramatically improves speed on repeat searches (cache hit = <500ms).
#  Without Redis, the app uses in-memory cache (fast but not persistent).
#  Recommended providers: Upstash (free tier), Redis Cloud, Railway
#
#  Format: redis://username:password@host:port
#  Upstash format: rediss://default:PASSWORD@HOST:PORT
#


# ─── App Config ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
